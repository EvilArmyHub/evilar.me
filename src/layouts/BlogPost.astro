---
import { type CollectionEntry, render } from "astro:content";

import Masthead from "@/components/blog/Masthead.astro";
import TOC from "@/components/blog/TOC.astro";
import WebMentions from "@/components/blog/webmentions/index.astro";
import { siteConfig } from "@/site.config";

import BaseLayout from "./Base.astro";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;
const { ogImage, title, description, updatedDate, publishDate } = post.data;
const socialImage = ogImage ?? `/og-image/${post.id}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { headings, remarkPluginFrontmatter } = await render(post);
const readingTime: string = remarkPluginFrontmatter.readingTime;
const authorUrl = new URL("/", siteConfig.url).href;
const postUrl = new URL(Astro.url.pathname, siteConfig.url).href;
---

<BaseLayout
	isArticleLayout
	meta={{
		articleDate,
		description,
		ogImage: socialImage,
		title,
		author: "Злая редакция",
	}}
>
	<article class="h-entry grow break-words" data-pagefind-body>
		<a class="u-url hidden" href={postUrl} aria-hidden="true" data-pagefind-ignore>{title}</a>
		<div class="mb-12" id="blog-hero" data-pagefind-ignore>
			<Masthead content={post} readingTime={readingTime} />
		</div>
		<div class="p-author h-card hidden" aria-hidden="true" data-pagefind-ignore>
			<a class="u-url p-name" href={authorUrl}>Злая редакция</a>
			<img class="u-photo" src="/icon.svg" alt="" />
		</div>
		<div class="relative w-full">
			{!!headings.length && <TOC headings={headings} />}
			<div
				class="e-content prose prose-headings:font-semibold prose-headings:text-heading prose-headings:before:absolute prose-headings:before:-ms-6 prose-headings:before:text-gray-600 prose-headings:hover:before:text-accent sm:prose-headings:before:content-['#'] sm:prose-th:before:content-none mx-auto w-full max-w-none"
			>
				<slot />
				<div data-pagefind-ignore>
					<WebMentions />
				</div>
			</div>
		</div>
	</article>
	<!-- Floating Action Buttons -->
	<button
		class="floating-action-btn floating-action-btn--scroll fixed end-4 bottom-8 z-[90] h-10 w-10 sm:end-8 sm:h-12 sm:w-12"
		data-show="false"
		id="to-top-btn"
		type="button"
	>
		<span class="sr-only">Back to top</span>
		<svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>

	<button
		class="floating-action-btn floating-action-btn--scroll fixed end-16 bottom-8 z-[90] h-10 sm:end-22 sm:h-12"
		data-show="false"
		id="copy-link-btn"
		type="button"
		title="Copy link"
	>
		<span class="sr-only">Copy link to clipboard</span>
		<svg
			id="copy-link-icon-url"
			aria-hidden="true"
			class="h-5 w-5 shrink-0"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path
				d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"
				stroke-linecap="round"
				stroke-linejoin="round"></path>
		</svg>
		<svg
			id="copy-link-icon-check"
			aria-hidden="true"
			class="floating-action-icon--check hidden h-5 w-5 shrink-0"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
		<span class="floating-action-copied-text text-sm font-medium">Скопировано</span>
	</button>
</BaseLayout>

<script>
	function initBlogPost() {
		const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
		const copyBtn = document.getElementById("copy-link-btn") as HTMLButtonElement;
		const targetHeader = document.getElementById("blog-hero") as HTMLDivElement;

		if (!scrollBtn || !copyBtn || !targetHeader) return;

		function callback(entries: IntersectionObserverEntry[]) {
			entries.forEach((entry) => {
				const show = (!entry.isIntersecting).toString();
				scrollBtn.dataset.show = show;
				copyBtn.dataset.show = show;
			});
		}

		scrollBtn.addEventListener("click", () => {
			document.documentElement.scrollTo({ behavior: "smooth", top: 0 });
		});

		const observer = new IntersectionObserver(callback);
		observer.observe(targetHeader);

		const copyIconUrl = document.getElementById("copy-link-icon-url") as HTMLElement;
		const copyIconCheck = document.getElementById("copy-link-icon-check") as HTMLElement;

		let copyTimeout: ReturnType<typeof setTimeout> | undefined;

		copyBtn.addEventListener("click", () => {
			const url = window.location.origin + window.location.pathname;
			navigator.clipboard.writeText(url).then(() => {
				copyIconUrl.classList.add("hidden");
				copyIconCheck.classList.remove("hidden");
				copyBtn.classList.add("is-copied");

				if (copyTimeout) clearTimeout(copyTimeout);
				copyTimeout = setTimeout(() => {
					copyIconUrl.classList.remove("hidden");
					copyIconCheck.classList.add("hidden");
					copyBtn.classList.remove("is-copied");
				}, 2000);
			});
		});
	}

	function initProseImages() {
		const proseImages = document.querySelectorAll(".prose img") as NodeListOf<HTMLImageElement>;
		proseImages.forEach((img) => {
			const adjustImageStyle = () => {
				if (img.naturalWidth === 0 || img.naturalHeight === 0) return;

				// Keep pixel-art and small images crisp by disabling smoothing
				if (img.naturalWidth < 500) {
					img.style.imageRendering = "pixelated";
				}

				const ratio = img.naturalWidth / img.naturalHeight;
				// Wide images (>= 16:10 ≈ 1.6, with margin down to 1.5) → full width
				// Narrower images → 2/3 width, left-aligned (handled by CSS default)
				if (ratio >= 1.5) {
					img.style.width = "100%";
				}
			};

			if (img.complete && img.naturalWidth > 0) {
				adjustImageStyle();
			} else {
				// Use decode() for reliable dimension access (especially AVIF)
				img.decode().then(adjustImageStyle).catch(() => {
					// Fallback to load event if decode fails
					img.addEventListener("load", adjustImageStyle, { once: true });
				});
			}
		});
	}

	document.addEventListener("astro:page-load", initBlogPost);
	document.addEventListener("astro:page-load", initProseImages);
</script>

