---
interface Props {
	isCompact?: boolean;
}

const { isCompact = false } = Astro.props;
---

<theme-toggle class:list={["ms-2 sm:ms-4", isCompact && "sm:ms-3"]}>
	<button
		class:list={[
			"hover:text-accent relative cursor-pointer rounded-md p-2",
			isCompact ? "h-8 w-8" : "h-9 w-9",
		]}
		type="button"
	>
		<span class="sr-only">Переключить тему</span>
		<svg
			aria-hidden="true"
			class:list={[
				"absolute start-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 scale-100 opacity-100 transition-all dark:scale-0 dark:opacity-0",
				isCompact ? "h-6 w-6" : "h-7 w-7",
			]}
			fill="none"
			focusable="false"
			stroke-width="1.5"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path
				d="M12 18C15.3137 18 18 15.3137 18 12C18 8.68629 15.3137 6 12 6C8.68629 6 6 8.68629 6 12C6 15.3137 8.68629 18 12 18Z"
				stroke="currentColor"
				stroke-linecap="round"
				stroke-linejoin="round"
			/>
			<path d="M22 12L23 12" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
			<path d="M12 2V1" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
			<path d="M12 23V22" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
			<path d="M20 20L19 19" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
			<path d="M20 4L19 5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
			<path d="M4 20L5 19" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
			<path d="M4 4L5 5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
			<path d="M1 12L2 12" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" />
		</svg>
		<svg
			aria-hidden="true"
			class:list={[
				"absolute start-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 scale-0 opacity-0 transition-all dark:scale-100 dark:opacity-100",
				isCompact ? "h-6 w-6" : "h-7 w-7",
			]}
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="1.5"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M0 0h24v24H0z" fill="none" stroke="none" />
			<path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z" />
			<path d="M17 4a2 2 0 0 0 2 2a2 2 0 0 0 -2 2a2 2 0 0 0 -2 -2a2 2 0 0 0 2 -2" />
			<path d="M19 11h2m-1 -1v2" />
		</svg>
	</button>
</theme-toggle>

<script>
	import { rootInDarkMode } from "@/utils/domElement";

	class ThemeToggle extends HTMLElement {
		#button: HTMLButtonElement | null = null;
		#onThemeApplied = () => {
			this.#button?.setAttribute("aria-checked", String(rootInDarkMode()));
		};

		connectedCallback() {
			this.#button = this.querySelector<HTMLButtonElement>("button");

			if (!this.#button) {
				console.warn("Theme toggle button not found");
				return;
			}

			this.#button.setAttribute("role", "switch");
			this.#button.setAttribute("aria-checked", String(rootInDarkMode()));
			this.#button.addEventListener("click", this.#onClick);
			document.addEventListener("theme-applied", this.#onThemeApplied);
		}

		disconnectedCallback() {
			this.#button?.removeEventListener("click", this.#onClick);
			document.removeEventListener("theme-applied", this.#onThemeApplied);
		}

		#onClick = () => {
			document.dispatchEvent(
				new CustomEvent("theme-change", {
					detail: {
						theme: rootInDarkMode() ? "light" : "dark",
					},
				}),
			);
		};
	}

	if (!customElements.get("theme-toggle")) {
		customElements.define("theme-toggle", ThemeToggle);
	}
</script>
