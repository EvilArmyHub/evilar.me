---
import { siteConfig } from "@/site.config";

interface Props {
	isCompact?: boolean;
}

const { isCompact = false } = Astro.props;
---

<a
	aria-current={Astro.url.pathname === "/" ? "page" : false}
	class:list={[
		"group inline-flex items-center transition-transform duration-300 ease-out focus-visible:outline-none active:scale-[0.98]",
		!isCompact && "sm:relative sm:inline-block",
	]}
	href="/"
>
	<img
		alt=""
		class:list={[
			"transition-transform duration-300 ease-out hover:scale-105",
			isCompact
				? "me-3 inline-block h-10 w-6 align-middle sm:me-6 sm:h-7 sm:w-4"
				: "me-3 h-10 w-6 sm:absolute sm:-start-18 sm:me-0 sm:h-15 sm:w-12",
		]}
		decoding="async"
		height="480"
		src="/icon.svg"
		width="515"
	/>
	{!isCompact && <span class="brand-title text-xl sm:text-2xl">{siteConfig.title}</span>}
</a>
