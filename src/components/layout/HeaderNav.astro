---
import { menuLinks } from "@/site.config";

interface Props {
	isCompact?: boolean;
	menuId: string;
}

const { isCompact = false, menuId } = Astro.props;
---

<nav
	aria-label="Главное меню"
	class:list={[
		"mobile-nav-dropdown hidden group-[.menu-open]:flex sm:static sm:z-auto sm:flex sm:w-auto sm:translate-y-0 sm:flex-row sm:items-center sm:rounded-none sm:border-0 sm:bg-transparent sm:p-0 sm:opacity-100 sm:shadow-none sm:backdrop-blur-none",
		isCompact ? "sm:mt-0" : "sm:ms-[1px] sm:mt-1",
	]}
	data-header-nav
	id={menuId}
>
	{
		menuLinks.map((link, index) => (
			<>
				<a
					aria-current={Astro.url.pathname === link.path ? "page" : false}
					class="mobile-nav-link nav-link aria-[current=page]:text-text sm:rounded-none sm:px-0 sm:py-0 sm:text-base sm:hover:bg-transparent"
					href={link.path}
				>
					{link.title}
				</a>
				{index < menuLinks.length - 1 && <span class="text-heading hidden px-2 sm:inline">·</span>}
			</>
		))
	}
</nav>
