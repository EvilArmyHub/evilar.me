---
import fs from "node:fs";
import path from "node:path";
import "@/styles/blocks/search.css";

interface Props {
	isCompact?: boolean;
}

const { isCompact = false } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const bundlePath = `${baseUrl.replace(/\/$/, "")}/pagefind/`;

const hasIndex = fs.existsSync(path.join(process.cwd(), "dist", "pagefind"));
const showDevWarning = import.meta.env.DEV && !hasIndex;
---

<div class="site-search ms-auto" data-compact={isCompact ? "true" : "false"} id="search">
	<pagefind-config base-url={baseUrl} bundle-path={bundlePath} lang="ru-RU"></pagefind-config>
	<pagefind-modal-trigger compact hide-shortcut placeholder="Открыть поиск"
	></pagefind-modal-trigger>
	{
		showDevWarning ? (
			<pagefind-modal id="site-search-modal">
				<pagefind-modal-body>
					<div class="site-search-dev-message">
						<p>
							Индекс поиска не найден.
							<br />
							Запустите <code>pnpm build</code> для его сборки.
						</p>
					</div>
				</pagefind-modal-body>
			</pagefind-modal>
		) : (
			<pagefind-modal id="site-search-modal" />
		)
	}
</div>

<script>
	import "@pagefind/component-ui";

	document.addEventListener("astro:before-swap", () => {
		const trigger = document.querySelector("pagefind-modal-trigger") as any;
		if (trigger?.instance) {
			trigger.instance.components = [];
			trigger.instance.componentsByType = {};
		}
	});
</script>
