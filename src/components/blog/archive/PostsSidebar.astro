---
interface Props {
	tags: string[];
}

const { tags } = Astro.props;
---

<aside>
	<h2 class="page-title mb-4 text-lg">
		Теги
	</h2>
	<ul class="flex flex-wrap gap-2">
		{
			tags.map((tag) => (
				<li>
					<a
						class="inline-flex items-center rounded-full bg-zinc-200 dark:bg-zinc-800 px-2.5 py-0.5 text-xs font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-300 dark:hover:bg-zinc-700 hover:text-black dark:hover:text-white active:scale-95 transition-all duration-200 ease-out focus-visible:outline-none"
						href={`/tags/${tag}/`}
					>
						<span class="sr-only">Открыть все статьи с этим тегом</span>
						#{tag}
					</a>
				</li>
			))
		}
	</ul>
	<span class="mt-4 block">
		<a class="action-link" href="/tags/">
			все теги
			<span class="sr-only">статей</span>
		</a>
	</span>
</aside>
