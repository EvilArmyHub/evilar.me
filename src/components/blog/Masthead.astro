---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import FormattedDate from "@/components/FormattedDate.astro";
import { getBlurhashDataUrl } from "@/utils/blurhash";
import { isFreshDate } from "@/utils/date";

interface Props {
	content: CollectionEntry<"post">;
	readingTime: string;
}

const {
	content: { data },
	readingTime,
} = Astro.props;

const dateTimeOptions: Intl.DateTimeFormatOptions = {
	month: "long",
};
const coverImageStyle = data.coverImage?.blurhash
	? `background-image: url("${getBlurhashDataUrl(data.coverImage.blurhash)}"); background-size: cover; background-position: center;`
	: undefined;
const isFresh = isFreshDate(data.publishDate);
---

{
	data.coverImage && (
		<div
			class="mb-6 aspect-video overflow-hidden bg-zinc-100 dark:bg-zinc-900"
			style={coverImageStyle}
		>
			<Image
				alt={data.coverImage.alt}
				class="h-full w-full"
				layout="constrained"
				width={748}
				height={420}
				priority
				src={data.coverImage.src}
			/>
		</div>
	)
}
<h1 class="p-name post-hero-title" data-pagefind-meta="title">{data.title}</h1>
<div class="mt-3 flex flex-wrap items-center gap-y-2">
	<p class="text-gray-600 dark:text-gray-400">
		{
			data.draft && (
				<span aria-label="Черновик" title="Черновик">
					🚧{" "}
				</span>
			)
		}
		{
			isFresh && (
				<span aria-label="Свежий материал" title="Свежий материал">
					🌱{" "}
				</span>
			)
		}
		<FormattedDate class="dt-published" date={data.publishDate} dateTimeOptions={dateTimeOptions} />
		{
			data.updatedDate && (
				<>
					<span class="px-2" aria-hidden="true">
						·
					</span>
					<span>
						обновлён{" "}
						<FormattedDate
							class="dt-updated"
							date={data.updatedDate}
							dateTimeOptions={dateTimeOptions}
						/>
					</span>
				</>
			)
		}
		<span class="px-2" aria-hidden="true">·</span>
		<span>{readingTime}</span>
	</p>
</div>
{
	!!data.tags?.length && (
		<div class="mt-3 flex flex-wrap items-center gap-2">
			{data.tags.map((tag) => (
				<a
					class="inline-flex items-center rounded-full bg-zinc-200 px-2.5 py-0.5 text-xs font-medium text-zinc-700 transition-all duration-200 ease-out hover:bg-zinc-300 hover:text-black focus-visible:outline-none active:scale-95 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-700 dark:hover:text-white"
					data-pagefind-filter={`tag:${tag}`}
					href={`/tags/${tag}/`}
				>
					<span class="sr-only">Открыть больше материалов с тегом&nbsp;</span>#{tag}
				</a>
			))}
		</div>
	)
}
