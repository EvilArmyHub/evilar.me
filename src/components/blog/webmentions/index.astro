---
import { getWebmentionsForUrls } from "@/utils/webmentions";
import Comments from "./Comments.astro";
import Likes from "./Likes.astro";

interface Props {
	legacyUrls?: string[];
}

const { legacyUrls = [] } = Astro.props;
const url = new URL(Astro.url.pathname, Astro.site);

const webMentions = await getWebmentionsForUrls([`${url}`, ...legacyUrls]).catch((error) => {
	console.warn(
		`Failed to load webmentions for ${[url, ...legacyUrls].join(", ")}: ${
			error instanceof Error ? error.message : "Unknown error"
		}`,
	);
	return [];
});

// Return if no webmentions
if (!webMentions.length) return;
---

<hr class="border-solid" />
<h2 class="mb-8 before:hidden">Отклики на эту статью</h2>
<div class="space-y-10">
	<Likes mentions={webMentions} />
	<Comments mentions={webMentions} />
</div>
<p class="mt-8">
	Отклики работают на базе{" "}
	<a href="https://webmention.io" rel="noreferrer" target="_blank">Webmentions</a>
</p>
