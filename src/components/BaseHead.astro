---
import { WEBMENTION_PINGBACK, WEBMENTION_URL } from "astro:env/client";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";
import "@/styles/global.css";

type Props = SiteMeta;

const { articleDate, description, ogImage, title, author = siteConfig.author } = Astro.props;

const titleSeparator = "·";
const siteTitle = `${title} ${titleSeparator} ${siteConfig.title}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(ogImage ?? "/social-card.png", Astro.site);
const socialImageExtension = socialImageURL.pathname.split(".").pop()?.toLowerCase();
const socialImageType =
	socialImageExtension === "jpg" || socialImageExtension === "jpeg"
		? "image/jpeg"
		: socialImageExtension
			? `image/${socialImageExtension}`
			: undefined;
---

<meta charset="utf-8" />
<meta content="width=device-width, initial-scale=1.0" name="viewport" />
<title>{siteTitle}</title>

{/* Google Fonts Preconnect and Roboto Flex Variable Font */}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Roboto+Flex:opsz,wdth,wght,GRAD,XOPQ,XTRA,YOPQ,YTAS,YTDE,YTFI,YTLC,YTUC,slnt@8..144,25..151,100..1000,-200..150,27..175,323..603,25..135,649..854,-305..-98,560..788,416..570,528..760,-10..0&display=swap"
	rel="stylesheet"
/>

{/* Icons */}
<link href="/icon.svg" rel="icon" type="image/svg+xml" />
{
	import.meta.env.PROD && (
		<>
			{/* Favicon & Apple Icon */}
			<link rel="icon" href="/favicon-32x32.png" type="image/png" />
			<link href="/icons/apple-touch-icon.png" rel="apple-touch-icon" />
			{/* Manifest */}
			<link href="/manifest.webmanifest" rel="manifest" />
		</>
	)
}

{/* Canonical URL */}
<link href={canonicalURL} rel="canonical" />

{/* Primary Meta Tags */}
<meta content={siteTitle} name="title" />
<meta content={description} name="description" />
<meta content={author} name="author" />

{/* Open Graph / Facebook */}
<meta content={articleDate ? "article" : "website"} property="og:type" />
<meta content={title} property="og:title" />
<meta content={description} property="og:description" />
<meta content={canonicalURL} property="og:url" />
<meta content={siteConfig.title} property="og:site_name" />
<meta content={siteConfig.ogLocale} property="og:locale" />
<meta content={socialImageURL} property="og:image" />
{socialImageType && <meta content={socialImageType} property="og:image:type" />}
<meta content="1200" property="og:image:width" />
<meta content="630" property="og:image:height" />
<meta content={title} property="og:image:alt" />
{
	articleDate && (
		<>
			<meta content={author} property="article:author" />
			<meta content={articleDate} property="article:published_time" />
		</>
	)
}

{/* Twitter */}
<meta content="summary_large_image" name="twitter:card" />
<meta content={canonicalURL} name="twitter:url" />
<meta content={title} name="twitter:title" />
<meta content={description} name="twitter:description" />
<meta content={socialImageURL} name="twitter:image" />
<meta content={title} name="twitter:image:alt" />

{/* Sitemap */}
<link href="/sitemap-index.xml" rel="sitemap" />

{/* RSS auto-discovery */}
<link href="/rss.xml" title="Статьи" rel="alternate" type="application/rss+xml" />
<link href="/notes/rss.xml" title="Заметки" rel="alternate" type="application/rss+xml" />

{/* Webmentions */}
{
	WEBMENTION_URL && (
		<>
			<link href={WEBMENTION_URL} rel="webmention" />
			{WEBMENTION_PINGBACK && <link href={WEBMENTION_PINGBACK} rel="pingback" />}
		</>
	)
}

{/* IndieAuth Verification / rel="me" */}
<link href="https://t.me/+o-QQtDMYJ4VlN2Iy" rel="me" />
<link href="https://github.com/EvilArmyHub" rel="me" />
<link href="https://www.youtube.com/@ResEvilTube" rel="me" />

<meta content={Astro.generator} name="generator" />
