---
import SocialButton from "@/components/SocialButton.astro";

const socialLinks: {
	friendlyName: string;
	isPlaceholder: boolean;
	link: string;
}[] = [
	{
		friendlyName: "Telegram",
		isPlaceholder: false,
		link: "https://t.me/",
	},
];
---

	<div class="flex flex-wrap items-center gap-3">
	<ul class="flex flex-1 items-center gap-3 sm:flex-initial">
		{
			socialLinks.map(({ friendlyName, isPlaceholder, link }) => (
				<li class="flex">
					<SocialButton href={link} isPlaceholder={isPlaceholder} label={friendlyName} />
				</li>
			))
		}
	</ul>
</div>
