---
import type { PaginationLink } from "@/types";

interface Props {
	nextUrl?: PaginationLink;
	prevUrl?: PaginationLink;
}

const { nextUrl, prevUrl } = Astro.props;
---

{
	(prevUrl || nextUrl) && (
		<nav class="mt-8 flex items-center gap-x-4">
			{prevUrl && (
				<a
					class="hover:text-accent me-auto py-2 transition-colors duration-250 ease-out focus-visible:outline-none active:opacity-75"
					href={prevUrl.url}
				>
					{prevUrl.srLabel && <span class="sr-only">{prevUrl.srLabel}</span>}
					{prevUrl.text ? prevUrl.text : "Назад"}
				</a>
			)}
			{nextUrl && (
				<a
					class="hover:text-accent ms-auto py-2 transition-colors duration-250 ease-out focus-visible:outline-none active:opacity-75"
					href={nextUrl.url}
				>
					{nextUrl.srLabel && <span class="sr-only">{nextUrl.srLabel}</span>}
					{nextUrl.text ? nextUrl.text : "Далее"}
				</a>
			)}
		</nav>
	)
}
