---
import PostPreview from "@/components/blog/PostPreview.astro";
import EvilIllustration from "@/components/EvilIllustration.astro";
import Note from "@/components/note/Note.astro";
import SocialList from "@/components/SocialList.astro";
import { getAllNotes, getLatestNotes } from "@/data/note";
import { getAllPosts, getPinnedPosts, getSortedPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";

// Restrict displayed posts to maintain optimal page loading speed.
const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = getSortedPosts(allPosts);
const latestPosts = allPostsByDate.slice(0, MAX_POSTS);

// Pin a small curated subset of posts to keep critical announcement or key items visible above the fold.
const MAX_PINNED_POSTS = 3;
const pinnedPosts = getPinnedPosts(allPostsByDate, MAX_PINNED_POSTS);

// Cap notes to avoid cluttering the home dashboard layout with micro-blogging content.
const MAX_NOTES = 5;
const allNotes = await getAllNotes();
const latestNotes = getLatestNotes(allNotes, MAX_NOTES);

function pluralizeRu(count: number, one: string, few: string, many: string) {
	const mod10 = count % 10;
	const mod100 = count % 100;

	if (mod10 === 1 && mod100 !== 11) {
		return one;
	}

	if (mod10 >= 2 && mod10 <= 4 && (mod100 < 12 || mod100 > 14)) {
		return few;
	}

	return many;
}

const remainingPosts = Math.max(allPostsByDate.length - latestPosts.length, 0);
const remainingNotes = Math.max(allNotes.length - latestNotes.length, 0);
const postsLinkText =
	remainingPosts > 0
		? `еще ${remainingPosts} ${pluralizeRu(remainingPosts, "статья", "статьи", "статей")}`
		: "все статьи";
const notesLinkText =
	remainingNotes > 0
		? `еще ${remainingNotes} ${pluralizeRu(remainingNotes, "заметка", "заметки", "заметок")}`
		: "все заметки";
---

<PageLayout meta={{ title: "Главная" }}>
	<section class="grid grid-cols-1 gap-y-6 sm:grid-cols-[1fr_auto] sm:items-center sm:gap-x-8">
		<div>
			<h1 class="title mb-3 text-2xl font-semibold sm:text-3xl">Уникальный чат</h1>
			<p class="mt-0 mb-3">
				Разношёрстное и живое комьюнити с 2018. Обсуждаем всё: нейросети, игры, науку, работу,
				учёбу, религию и жизнь
			</p>
			<p class="mb-4">
				Пишем 1500+ сообщений в день, ламповая атмосфера и постоянный состав. Студенты,
				программисты, музыканты и кого только нет
			</p>
			<SocialList />
		</div>
		<div class="flex w-full flex-shrink-0 items-center justify-center sm:h-[20rem] sm:w-auto">
			<EvilIllustration class="text-text h-auto w-full max-w-full sm:h-full sm:w-auto" />
		</div>
	</section>
	{
		pinnedPosts.length > 0 && (
			<section class="mt-10">
				<h2 class="page-title mb-3 text-xl">Ключевое</h2>
				<ul class="space-y-1" role="list">
					{pinnedPosts.map((p) => (
						<li>
							<PostPreview post={p} />
						</li>
					))}
				</ul>
			</section>
		)
	}
	<section class="mt-10">
		<h2 class="page-title mb-3 text-xl">Статьи</h2>
		<ul class="space-y-1" role="list">
			{
				latestPosts.map((p) => (
					<li>
						<PostPreview post={p} />
					</li>
				))
			}
		</ul>
		<a class="action-link mt-4" href="/posts/">{postsLinkText}</a>
	</section>
	{
		latestNotes.length > 0 && (
			<section class="mt-10">
				<h2 class="page-title mb-3 text-xl">Заметки</h2>
				<ul class="space-y-4" role="list">
					{latestNotes.map((note) => (
						<li>
							<Note note={note} as="h3" isPreview />
						</li>
					))}
				</ul>
				<a class="action-link mt-4" href="/notes/">
					{notesLinkText}
				</a>
			</section>
		)
	}
</PageLayout>
